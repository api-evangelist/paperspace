{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paperspace Datasets API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Datasets",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Datasets",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/datasets",
            "params": [
              {
                "name": "after",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Lists datasets available to the team."
        },
        {
          "info": {
            "name": "Create Dataset",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paperspace.com/v1/datasets",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new dataset."
        },
        {
          "info": {
            "name": "Get Dataset",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/datasets/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Gets a dataset by ID."
        },
        {
          "info": {
            "name": "Update Dataset",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.paperspace.com/v1/datasets/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates a dataset's metadata."
        },
        {
          "info": {
            "name": "Delete Dataset",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.paperspace.com/v1/datasets/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Deletes a dataset and its versions."
        }
      ]
    },
    {
      "info": {
        "name": "Dataset Versions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Dataset Versions",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/datasets/:datasetId/versions",
            "params": [
              {
                "name": "datasetId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Lists versions of a dataset."
        },
        {
          "info": {
            "name": "Create Dataset Version",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paperspace.com/v1/datasets/:datasetId/versions",
            "params": [
              {
                "name": "datasetId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new dataset version."
        },
        {
          "info": {
            "name": "Get Dataset Version",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/datasets/:datasetId/versions/:version",
            "params": [
              {
                "name": "datasetId",
                "value": "",
                "type": "path"
              },
              {
                "name": "version",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Gets a specific dataset version."
        },
        {
          "info": {
            "name": "Update Dataset Version",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.paperspace.com/v1/datasets/:datasetId/versions/:version",
            "params": [
              {
                "name": "datasetId",
                "value": "",
                "type": "path"
              },
              {
                "name": "version",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates the metadata or message of a dataset version."
        },
        {
          "info": {
            "name": "Delete Dataset Version",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.paperspace.com/v1/datasets/:datasetId/versions/:version",
            "params": [
              {
                "name": "datasetId",
                "value": "",
                "type": "path"
              },
              {
                "name": "version",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Deletes a dataset version."
        }
      ]
    }
  ],
  "bundled": true
}