{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paperspace Deployments API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Deployments",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Deployments",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/deployments",
            "params": [
              {
                "name": "after",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Fetches a list of deployments for the authenticated team."
        },
        {
          "info": {
            "name": "Create or Update Deployment",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paperspace.com/v1/deployments",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Submits a new deployment configuration. If the deployment does not exist one is created; otherwise a new run is started against the existing deployment."
        },
        {
          "info": {
            "name": "Get Deployment",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/deployments/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Fetches a single deployment by deployment ID."
        },
        {
          "info": {
            "name": "Delete Deployment",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.paperspace.com/v1/deployments/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Removes a deployment using its identifier."
        },
        {
          "info": {
            "name": "List Deployment Runs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/deployments/:id/runs",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Lists the active deployment runs for a deployment."
        },
        {
          "info": {
            "name": "Get Deployment Metrics",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/deployments/:id/metrics",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "start",
                "value": "",
                "type": "query"
              },
              {
                "name": "end",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieves performance data for a given deployment over a time range."
        },
        {
          "info": {
            "name": "Get Deployment Logs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/deployments/:id/logs",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Obtains log entries associated with a deployment."
        },
        {
          "info": {
            "name": "Get Deployment History",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/deployments/:id/history",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Accesses configuration change records for a deployment."
        },
        {
          "info": {
            "name": "List Project Deployments",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/projects/:id/deployments",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Fetches a list of deployments scoped to a specific project."
        }
      ]
    }
  ],
  "bundled": true
}