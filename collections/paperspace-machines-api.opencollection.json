{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paperspace Machines API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Machines",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Machines",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machines",
            "params": [
              {
                "name": "after",
                "value": "",
                "type": "query",
                "description": "Pagination cursor."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "orderBy",
                "value": "",
                "type": "query"
              },
              {
                "name": "order",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Fetches a list of machines visible to the caller's team."
        },
        {
          "info": {
            "name": "Create Machine",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paperspace.com/v1/machines",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Provisions a new Paperspace machine in the specified region with the chosen machine type and template."
        },
        {
          "info": {
            "name": "Get Machine",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machines/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Fetches a single machine by ID."
        },
        {
          "info": {
            "name": "Update Machine",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.paperspace.com/v1/machines/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates a machine — name, auto-shutdown, public IP, machine type, and other mutable fields."
        },
        {
          "info": {
            "name": "Delete Machine",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.paperspace.com/v1/machines/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Deletes a single machine by ID and releases the associated resources."
        },
        {
          "info": {
            "name": "Start Machine",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.paperspace.com/v1/machines/:id/start",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Starts a stopped machine."
        },
        {
          "info": {
            "name": "Stop Machine",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.paperspace.com/v1/machines/:id/stop",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Stops a running machine — compute billing pauses; storage continues to bill."
        },
        {
          "info": {
            "name": "Restart Machine",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.paperspace.com/v1/machines/:id/restart",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Restarts a machine."
        },
        {
          "info": {
            "name": "Get Desktop Streaming Configuration",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machines/:id/desktop",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieves desktop streaming configuration settings used by the Paperspace client."
        }
      ]
    },
    {
      "info": {
        "name": "Machine Access",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Machine Accessors",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machines/:id/accessors",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Lists team members with explicit access to the machine."
        },
        {
          "info": {
            "name": "Grant Machine Access",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paperspace.com/v1/machines/:id/accessors",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Grants machine access to a team member."
        },
        {
          "info": {
            "name": "Get Machine Accessor",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machines/:id/accessors/:userId",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieves accessor information for a specific user."
        },
        {
          "info": {
            "name": "Revoke Machine Access",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.paperspace.com/v1/machines/:id/accessors/:userId",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Revokes a user's machine access."
        }
      ]
    },
    {
      "info": {
        "name": "Machine Events",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Machine Events",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machine-events",
            "params": [
              {
                "name": "after",
                "value": "",
                "type": "query",
                "description": "Pagination cursor."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Fetches a page of machine events across the team."
        },
        {
          "info": {
            "name": "Get Machine Event",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machine-events/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Fetches a single machine event by ID."
        }
      ]
    },
    {
      "info": {
        "name": "Machine Types",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Machine Availability",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/machine-availability",
            "params": [
              {
                "name": "machineType",
                "value": "",
                "type": "query"
              },
              {
                "name": "region",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Gets the machine availability for a given region and machine type."
        }
      ]
    }
  ],
  "bundled": true
}