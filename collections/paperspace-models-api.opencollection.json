{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paperspace Models API",
    "version": "v1"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Models",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Models",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/models"
          },
          "docs": "Lists models accessible to the team."
        },
        {
          "info": {
            "name": "Create Model",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paperspace.com/v1/models",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Registers a new model with the Gradient model registry."
        },
        {
          "info": {
            "name": "Get Model",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paperspace.com/v1/models/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Gets a model by ID."
        },
        {
          "info": {
            "name": "Delete Model",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.paperspace.com/v1/models/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Deletes a model from the registry."
        }
      ]
    }
  ],
  "bundled": true
}